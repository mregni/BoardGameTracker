{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:6708",
      "sslPort": 44309
    }
  },
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "http://127.0.0.1:6554",
      "environmentVariables": {
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ENV_ASPNETCORE_URLS": "http://*:5444",
        "STATISTICS_ENABLED": "true",
        "LOGLEVEL": "debug",
        "TZ": "Europe/Brussels",
        "DB_HOST": "localhost",
        "DB_USER": "dev",
        "DB_PASSWORD": "dev",
        "DB_NAME": "boardgametracker-dev",
        "DB_PORT": "5432",
        "AUTH_ENABLED": "true"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "https://localhost:6554",
      "environmentVariables": {
        "ASPNETCORE_HOSTINGSTARTUPASSEMBLIES": "Microsoft.AspNetCore.SpaProxy",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ENV_ASPNETCORE_URLS": "http://*:5444",
        "STATISTICS_ENABLED": "true",
        "TZ": "Europe/Brussels",
        "DB_HOST": "localhost",
        "DB_USER": "dev",
        "DB_PASSWORD": "dev"
      }
    }
  }
}
